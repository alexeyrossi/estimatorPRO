{
  "name": "next-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "ci:check": "npm run lint && npm run test && npm run build",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "bench:hotpath": "node tests/perf/hotpath.mjs",
    "regression": "node tests/regression/run-regression.mjs",
    "regression:gold": "node tests/regression/run-regression.mjs --tier gold",
    "regression:update": "node tests/regression/run-regression.mjs --update",
    "regression:update:gold": "node tests/regression/run-regression.mjs --tier gold --update --allow-gold-update",
    "test": "npm run test:unit && npm run regression"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-countup": "^6.5.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
